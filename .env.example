# LLM provider: ollama | anthropic | openai
LLM_PROVIDER=anthropic

# Ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen3.5-9b-custom:latest

# Anthropic via proxy — use with LLM_PROVIDER=anthropic
ANTHROPIC_MODEL=anthropic.claude-4-6-sonnet
ANTHROPIC_BASE_URL=https://your-llm-proxy-url
ANTHROPIC_AUTH_TOKEN=your-auth-token

# OpenAI — use with LLM_PROVIDER=openai
# OPENAI_MODEL=gpt-4o
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=  # opcional, para endpoints customizados

TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_URL=https://your-ngrok-or-public-url

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET_TOKEN=your-webhook-secret-token

# Required for `make admin-invite` link generation (sem o `@`).
# TELEGRAM_BOT_USERNAME=your_bot_name

# Discord — https://discord.com/developers/applications → Bot → Token
# DISCORD_APP_TOKEN=your-discord-bot-token

# Fine-grained PAT for smsilva/wasp-gitops (Contents: write).
# Setup: docs/runbooks/github-pat-setup.md
GH_PAT=your-github-pat

# GitOps repo (owner/repo) — required.
GITOPS_REPO=your-org/your-gitops-repo

# GitHub API base URL — required. Override for GitHub Enterprise.
GITHUB_BASE_URL=https://api.github.com

# WARNING: APP_ENV=development disables webhook authentication entirely.
# Never set this in production.
# APP_ENV=development

# Local chat (path D em validation.md) — sem Telegram.
# Default: 'telegram' se TELEGRAM_TOKEN estiver setado, senão 'console'.
# AGENT_NOTIFIER=console

# AGENT_URL=http://localhost:7777
# AGENT_ID=wasp-agent

# Auth (multi-channel allowlist) — ver docs/runbooks/auth-admin.md

# Backend de persistência (auth + sessões agno).
# Valores: 'sqlite' (default), 'postgres'.
# DATABASE_BACKEND=sqlite

# Path do arquivo SQLite — ignorado se DATABASE_BACKEND != sqlite.
# DATABASE_FILE=agent.db

# DSN do Postgres — ignorado se DATABASE_BACKEND=sqlite.
# DATABASE_URL=postgresql://wasp:wasp@localhost:5432/wasp_agent

# Postgres (docker-compose) — usar com DATABASE_BACKEND=postgres
# POSTGRES_USER=wasp
# POSTGRES_PASSWORD=wasp
# POSTGRES_DB=wasp_agent

# AGENT_INVITE_TTL_HOURS=1

# Habilita endpoint /telemetry/prometheus. Ver: make smoke-prometheus
# PROMETHEUS_METRICS_ACTIVE=true

# Structured logging
# LOG_FORMAT=text              # text | json (default: text)
# LOG_LEVEL=DEBUG              # stdout handler level (default: INFO)
# LOG_FILE=logs/wasp.jsonl     # JSONL file path; absent = no file handler
# LOG_FILE_LEVEL=DEBUG         # file handler level (default: DEBUG)
# LOG_FILE_MAX_BYTES=52428800  # rotation size in bytes (default: 50 MB)
# LOG_FILE_BACKUP_COUNT=7      # rotated files to keep (default: 7)
