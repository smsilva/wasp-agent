#!/bin/bash
set -e

cluster_name="${1:-wasp-local}"

k3d cluster delete "${cluster_name}" 2>/dev/null || true
k3d cluster create "${cluster_name}"
kubectl wait \
  --context "k3d-${cluster_name}" \
  --for=condition=Ready node --all \
  --timeout=120s
kubectl apply \
  --context "k3d-${cluster_name}" \
  --validate=false \
  --filename tests/e2e/fixtures/platform-crd.yaml
