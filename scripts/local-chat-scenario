#!/usr/bin/env bash
# Replays the Telegram smoke roteiro via local-chat: greet → memory → request → confirm.
# No asserts on LLM content (non-deterministic) — only that each request returned 200.
set -e

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PATH="${SCRIPT_DIR}:${PATH}"
export PATH

step() {
  local label="${1?}" message="${2?}" reply
  echo
  echo "─── ${label} ───"
  echo "> ${message}"
  echo
  reply="$(local-chat "${message}")"
  echo "${reply}"
}

echo "session: $(local-chat --new-session)"
step "1/5 greet" "hi"
step "2/5 memory write" "My name is John."
step "3/5 memory recall" "What is my name?"
step "4/5 request" "Create a platform named test-smoke in region us-east-1."
step "5/5 confirm" "Yes, confirm."

echo
echo "Script completed. Check the server stdout (make run) for the ConsoleNotifier."
