#!/usr/bin/env bash
set -e

user_id="${1?usage: admin-link USER_ID CHANNEL CHANNEL_ID}"
channel="${2?usage: admin-link USER_ID CHANNEL CHANNEL_ID}"
channel_id="${3?usage: admin-link USER_ID CHANNEL CHANNEL_ID}"

uv run python -m wasp.auth_cli link \
  --user-id "${user_id}" \
  --channel "${channel}" \
  --channel-id "${channel_id}"
