#!/bin/bash
set -e

repo_dir="$(cd "$(dirname "${0}")/.." && pwd)"
kubernetes_repo="${KUBERNETES_REPO:-${HOME}/git/kubernetes}"
argocd_lab="${kubernetes_repo}/lab/argo/argocd"

if [[ ! -d "${argocd_lab}" ]]; then
  echo "Diretório não encontrado: ${argocd_lab}" >&2
  echo "Clone https://github.com/smsilva/kubernetes em \${KUBERNETES_REPO} (default: ~/git/kubernetes)." >&2
  exit 1
fi

echo "==> [1/6] Cluster k3d + ArgoCD + Crossplane (via ${argocd_lab}/run)"
cd "${argocd_lab}"

# run usa ". ./argocd-get-initial-password.sh" (source com caminho relativo),
# então substituímos temporariamente o arquivo por um no-op para suprimir
# as credenciais no meio da execução — elas são exibidas ao final.
password_script="${argocd_lab}/argocd-get-initial-password.sh"
password_script_backup=$(mktemp)
cp "${password_script}" "${password_script_backup}"
echo '#!/bin/bash' > "${password_script}"
trap "cp '${password_script_backup}' '${password_script}'; rm -f '${password_script_backup}'" EXIT

bash run

cp "${password_script_backup}" "${password_script}"
rm -f "${password_script_backup}"
trap - EXIT

cd "${repo_dir}"

echo "==> [2/6] Provider upbound/provider-kubernetes"
kubectl apply \
  --filename manifests/crossplane/providers/kubernetes.yaml

kubectl wait provider/provider-kubernetes \
  --for=condition=Healthy \
  --timeout=120s

echo "==> [3/6] ProviderConfig + ClusterRoleBinding"
kubectl apply \
  --filename manifests/crossplane/providerconfigs/kubernetes.yaml

echo "==> [4/6] function-patch-and-transform"
kubectl apply \
  --filename manifests/crossplane/functions/patch-and-transform.yaml

kubectl wait function/function-patch-and-transform \
  --for=condition=Healthy \
  --timeout=120s

echo "==> [5/6] XRD + Composition de Platform"
kubectl apply \
  --filename manifests/crossplane/xrd/platform.yaml

kubectl apply \
  --filename manifests/crossplane/compositions/platform.yaml

echo "==> [6/6] Application wasp-gitops"
kubectl apply \
  --filename manifests/argocd/wasp-gitops-application.yaml

argocd_password=$(kubectl \
  --namespace argocd \
  get secret argocd-initial-admin-secret \
  --output jsonpath="{.data.password}" | base64 -d)

echo "==> Login no ArgoCD"
argocd login localhost:32080 \
  --username admin \
  --password "${argocd_password}" \
  --insecure

echo "==> Status da Application wasp-gitops"
argocd app get wasp-gitops

echo
echo "Comandos úteis:"
echo "  argocd app get wasp-gitops"
echo "  argocd app sync wasp-gitops"
echo
echo "Credenciais ArgoCD:"
echo "  user:     admin"
echo "  password: ${argocd_password}"
echo "  url:      http://localhost:32080"
echo
echo "Outros recursos:"
echo "  kubectl get providers,functions,xrds,compositions"